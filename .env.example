# --- Copy to ".env" and adjust values (never commit .env) ---

# PostgreSQL: host must be reachable from where the app runs.
# Local (Docker or installed Postgres):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lms?schema=public

# Prisma migrate uses DIRECT_URL. For normal Postgres you can copy DATABASE_URL here,
# or leave unset — local scripts set DIRECT_URL = DATABASE_URL when not using a pooler.
# Supabase: keep DATABASE_URL as pooler (often :6543); set DIRECT_URL to "Direct connection" (port 5432).
# Neon (Vercel integration often provides unpooled URL — scripts map it to DIRECT_URL automatically):
# DATABASE_URL_UNPOOLED=  or  POSTGRES_URL_NON_POOLING=
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/lms?schema=public

# Vercel / production: use Vercel Postgres, Neon, Supabase, etc.
# The hostname MUST NOT be localhost (Vercel cannot reach your PC).
# Or connect Vercel Postgres and rely on POSTGRES_URL / POSTGRES_PRISMA_URL
# (see README — build scripts map those to DATABASE_URL when needed).

# Session signing secret. Use a long random string; no spaces; do NOT wrap in quotes
# in Vercel’s UI (paste the raw string only).
# Generate a new one anytime:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Optional: migration strategy during build.
# On Vercel, migrations run by default to avoid missing-table runtime errors.
# Set to 0/false/no only when you intentionally handle migrations elsewhere.
# RUN_PRISMA_MIGRATIONS=1
