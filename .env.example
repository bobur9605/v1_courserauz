# Required for Prisma: must start with postgresql:// or postgres://
# Local example:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# JWT (any long random string in production)
JWT_SECRET="generate-a-long-random-secret-min-32-chars"

# Vercel: If you use "Vercel Postgres", these are created automatically.
# This repo maps them to DATABASE_URL during build if DATABASE_URL is empty:
#   POSTGRES_PRISMA_URL  (preferred for Prisma)
#   POSTGRES_URL
# You can instead set DATABASE_URL manually to the same value.
