# Required for Prisma: must start with postgresql:// or postgres://
# Local example (Postgres on your PC or Docker):
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# JWT (any long random string in production)
JWT_SECRET="generate-a-long-random-secret-min-32-chars"

# --- Vercel / Production ---
# Never paste a "localhost" URL into Vercel — builds run in the cloud and
# cannot reach your laptop. Use Vercel Postgres, Neon, or Supabase.
#
# Recommended: add **Vercel → Storage → Postgres**. Then either:
#   - leave DATABASE_URL empty in Vercel (we use POSTGRES_PRISMA_URL), or
#   - set DATABASE_URL to the SAME connection string shown in the Vercel storage UI,
#     which must be a public hostname (not localhost).
#
# Optional fallbacks we read if DATABASE_URL is missing:
#   POSTGRES_PRISMA_URL, POSTGRES_URL, PRISMA_DATABASE_URL, NEON_DATABASE_URL
