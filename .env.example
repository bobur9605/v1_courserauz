# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Server only — same page, "service_role" secret (never expose to the browser or client bundles)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Session signing (JWT cookie). Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
