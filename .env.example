# --- Copy to ".env" and adjust values (never commit .env) ---

# PostgreSQL: host must be reachable from where the app runs.
# Local (Docker or installed Postgres):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lms?schema=public

# Vercel / production: use Vercel Postgres, Neon, Supabase, etc.
# The hostname MUST NOT be localhost (Vercel cannot reach your PC).
# Or connect Vercel Postgres and rely on POSTGRES_URL / POSTGRES_PRISMA_URL
# (see README — build scripts map those to DATABASE_URL when needed).

# Session signing secret. Use a long random string; no spaces; do NOT wrap in quotes
# in Vercel’s UI (paste the raw string only).
# Generate a new one anytime:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
